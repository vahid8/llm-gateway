# --- Storage -----------------------------------------------------------
# SQLite (default, zero-infra). For Postgres:
#   DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/gateway
DATABASE_URL=sqlite+aiosqlite:///./gateway.db

# --- Admin -------------------------------------------------------------
# Guards key management (/admin/keys) and the dashboard (/api/stats).
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=change-me

# --- Provider credentials (server-side only; never sent to clients) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Doubleword — OpenAI-compatible, high-throughput cloud for open models
# (Qwen, GLM, …). Call models as `doubleword/<id>`, e.g.
# doubleword/Qwen/Qwen3-VL-235B-A22B-Instruct-FP8. Default base URL below.
DOUBLEWORD_API_KEY=
# DOUBLEWORD_BASE_URL=https://api.doubleword.ai/v1

# --- Secrets as files (preferred over the inline keys above) -----------
# Any *_API_KEY_FILE wins over the matching *_API_KEY. Point it at a Docker
# secret (/run/secrets/<name>, set automatically by docker-compose) or, for
# local dev, a file under ~/.secrets so the key never lives in this .env:
#   DOUBLEWORD_API_KEY_FILE=/home/you/.secrets/doubleword.key
# OPENAI_API_KEY_FILE=
# ANTHROPIC_API_KEY_FILE=
# GEMINI_API_KEY_FILE=
# DOUBLEWORD_API_KEY_FILE=
# With docker-compose, set DOUBLEWORD_KEY_FILE to the host path of the key file
# that gets mounted as the `doubleword_key` secret:
# DOUBLEWORD_KEY_FILE=/home/you/.secrets/doubleword.key

# --- Optional ----------------------------------------------------------
# Comma-separated CORS allowlist for the dashboard (avoid "*" in prod).
CORS_ORIGINS=*
# Reliability
REQUEST_TIMEOUT_SECONDS=120
MAX_RETRIES=2
# Default per-key rate limit on /v1/chat/completions (requests/minute).
# 0 = disabled. A key's own rate_limit_per_min (set at creation) overrides this.
RATE_LIMIT_PER_MINUTE=0
# Default per-key monthly spend cap in USD (UTC calendar month). 0 = unlimited.
# A key's own monthly_budget_usd (set at creation) overrides this. Over budget -> 402.
MONTHLY_BUDGET_USD=0
# Friendly client-facing model aliases -> litellm model names (JSON).
# MODEL_ALIASES={"fast":"gemini/gemini-1.5-flash","smart":"anthropic/claude-sonnet-4-20250514","qwen-vl":"doubleword/Qwen/Qwen3-VL-235B-A22B-Instruct-FP8"}
MODEL_ALIASES={}
