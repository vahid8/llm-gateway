# --- Storage -----------------------------------------------------------
# SQLite (default, zero-infra). For Postgres:
#   DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/gateway
DATABASE_URL=sqlite+aiosqlite:///./gateway.db

# --- Admin -------------------------------------------------------------
# Guards key management (/admin/keys) and the dashboard (/api/stats).
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=change-me

# --- Provider credentials (server-side only; never sent to clients) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Optional ----------------------------------------------------------
# Comma-separated CORS allowlist for the dashboard (avoid "*" in prod).
CORS_ORIGINS=*
# Reliability
REQUEST_TIMEOUT_SECONDS=120
MAX_RETRIES=2
# Default per-key rate limit on /v1/chat/completions (requests/minute).
# 0 = disabled. A key's own rate_limit_per_min (set at creation) overrides this.
RATE_LIMIT_PER_MINUTE=0
# Friendly client-facing model aliases -> litellm model names (JSON).
# MODEL_ALIASES={"fast":"gemini/gemini-1.5-flash","smart":"anthropic/claude-sonnet-4-20250514"}
MODEL_ALIASES={}
